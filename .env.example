# Foxloop2 Workflows - Environment Configuration Example
# Copy this file to .env and fill in the required values

## Engine path (required)
AP_ENGINE_EXECUTABLE_PATH=dist/packages/engine/main.js

## Security Keys - IMPORTANT: Generate unique values for production!
## Use: openssl rand -hex 16 for encryption key
## Use: openssl rand -hex 32 for JWT secret
AP_API_KEY=
AP_ENCRYPTION_KEY=
AP_JWT_SECRET=

## Environment and URLs
AP_ENVIRONMENT=prod
AP_FRONTEND_URL=http://localhost:8080
AP_WEBHOOK_TIMEOUT_SECONDS=30
AP_TRIGGER_DEFAULT_POLL_INTERVAL=5

## Database Configuration
AP_POSTGRES_DATABASE=foxloop2
AP_POSTGRES_HOST=postgres
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME=foxloop2
AP_POSTGRES_PASSWORD=

## Execution Mode
AP_EXECUTION_MODE=UNSANDBOXED
AP_FLOW_TIMEOUT_SECONDS=600

## Redis Configuration
AP_REDIS_HOST=redis
AP_REDIS_PORT=6379

## Foxloop2 Specific Configuration
# Disable cloud auth (embedded in Foxloop2 app which handles auth)
AP_CLOUD_AUTH_ENABLED=false

# Disable telemetry for privacy
AP_TELEMETRY_ENABLED=false

# Templates source - leave empty to disable external templates
AP_TEMPLATES_SOURCE_URL=
